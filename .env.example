# ─── App ─────────────────────────────────────────────────────────────────────
# development | staging | production
APP_ENV=development

# Generate with: openssl rand -hex 32 (Render sets this automatically in prod)
SECRET_KEY=changeme

HOST=127.0.0.1
PORT=8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Development default is the Vite dev server.
# Production: set to your Render frontend URL.
ALLOWED_ORIGINS=http://localhost:5173

# ─── Contact form ────────────────────────────────────────────────────────────
# Address contact submissions are directed to. Delivery is logged by default;
# wire real email/SMTP as a follow-up (see backend/app/services/contact.py).
CONTACT_EMAIL=robertsamsolutions@gmail.com

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── Optional integrations (unused by default) ───────────────────────────────
# The template ships a dormant Pydantic-AI agent and Supabase Storage helpers.
# Leave these blank unless/until you enable those features.
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# STORAGE_BUCKET=uploads
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
